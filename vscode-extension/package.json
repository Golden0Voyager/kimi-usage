{
  "name": "kimi-code-usage",
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "icon": "assets/icon.png",
  "publisher": "HainingYu",
  "author": "Haining Yu",
  "license": "MIT",
  "version": "0.1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Golden0Voyager/kimi_usage"
  },
  "homepage": "https://github.com/Golden0Voyager/kimi_usage#readme",
  "bugs": {
    "url": "https://github.com/Golden0Voyager/kimi_usage/issues"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "l10n": "./l10n",
  "contributes": {
    "configuration": {
      "title": "Kimi Usage",
      "properties": {
        "kimiUsage.apiKey": {
          "type": "string",
          "default": "",
          "description": "%config.apiKey.description%"
        },
        "kimiUsage.baseUrl": {
          "type": "string",
          "default": "https://api.kimi.com/coding/v1",
          "description": "%config.baseUrl.description%"
        },
        "kimiUsage.refreshIntervalMinutes": {
          "type": "number",
          "default": 5,
          "description": "%config.refreshIntervalMinutes.description%"
        },
        "kimiUsage.warnPercent": {
          "type": "number",
          "default": 30,
          "description": "%config.warnPercent.description%"
        },
        "kimiUsage.criticalPercent": {
          "type": "number",
          "default": 10,
          "description": "%config.criticalPercent.description%"
        }
      }
    },
    "commands": [
      {
        "command": "kimiUsage.refresh",
        "title": "%command.refresh.title%",
        "category": "Kimi"
      },
      {
        "command": "kimiUsage.showDetails",
        "title": "%command.showDetails.title%",
        "category": "Kimi"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.74.0",
    "typescript": "^5.0.0"
  }
}
